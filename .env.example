TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret

DEEPGRAM_API_KEY=your_deepgram_api_key
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=tr

ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

GOOGLE_API_KEY=your_google_ai_studio_key
# GEMINI_API_KEY= is also accepted as a fallback.
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=1200
GEMINI_RETRY_ATTEMPTS=3
GEMINI_RETRY_BASE_DELAY_SECONDS=1.5
# Optional: set for preview Gemini 3 models, for example low or minimal.
GEMINI_THINKING_LEVEL=

QDRANT_URL=your_qdrant_cluster_url
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION=economy_knowledge
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768

MARKET_DEFAULT_SYMBOLS=BIST100,SP500,NASDAQ,DAX,BRENT,GOLD,USDTRY,EURTRY,BTCUSD
NEWS_MAX_ITEMS=5
NEWS_MOVE_THRESHOLD_PERCENT=2.0
APP_TIMEZONE=Europe/Istanbul
